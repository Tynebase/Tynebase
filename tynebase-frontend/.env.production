# ============================================================================
# TYNEBASE PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Production configuration for Vercel deployment
# These values should be configured in Vercel's environment variables UI

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Production Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co

# New Supabase API Keys (preferred)
# Use the publishable key for client-side operations
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-production-publishable-key

# Secret key for server-side operations (set in Vercel environment variables)
SUPABASE_SECRET_KEY=sb_secret_your-production-secret-key


# ----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ----------------------------------------------------------------------------
# Production application URL (your Vercel domain or custom domain)
NEXT_PUBLIC_APP_URL=https://www.tynebase.com

# Backend API URL (Fly.io production deployment)
# Replace with your actual Fly.io app URL
NEXT_PUBLIC_API_URL=https://tynebase-backend.fly.dev

# WebSocket Collaboration Server URL (Hocuspocus on Fly.io)
# Replace with your actual Fly.io collab server URL
NEXT_PUBLIC_WS_URL=wss://tynebase-collab.fly.dev

# Node environment
NODE_ENV=production

# ----------------------------------------------------------------------------
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ----------------------------------------------------------------------------
# Google OAuth (if using Google sign-in)
#GOOGLE_CLIENT_ID=your-production-google-client-id
#GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# GitHub OAuth (if using GitHub sign-in)
#GITHUB_CLIENT_ID=your-production-github-client-id
#GITHUB_CLIENT_SECRET=your-production-github-client-secret

# ----------------------------------------------------------------------------
# VERCEL DEPLOYMENT INSTRUCTIONS
# ----------------------------------------------------------------------------
# 1. Go to your Vercel project settings > Environment Variables
# 2. Add all NEXT_PUBLIC_* variables (these are exposed to the browser)
# 3. Add secret variables (SUPABASE_SECRET_KEY, GOOGLE_CLIENT_SECRET, etc.)
# 4. Set environment scope to "Production" for production-only variables
# 5. Redeploy after updating environment variables
#
# SECURITY NOTES:
# - Never commit actual production values to git
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Keep SUPABASE_SECRET_KEY and other secrets server-side only
# - Configure OAuth redirect URLs in your OAuth provider settings
# - Update CORS settings in backend to allow your production domain
