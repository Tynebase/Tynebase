{
  "installCommand": "cd tynebase-frontend && npm install",
  "buildCommand": "cd tynebase-frontend && NEXT_DISABLE_TURBOPACK=1 next build",
  "devCommand": "cd tynebase-frontend && npm run dev",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tynebase-backend.fly.dev/api/:path*"
    }
  ]
}